# Payload CMS
PAYLOAD_SECRET=your-random-secret-at-least-32-chars-long

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Site
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database (optional, defaults to file:./payload.db)
DATABASE_URI=file:./payload.db

# Issuer service (optional - for scholarship/access code redemption)
ISSUER_SERVICE_BASE_URL=https://issuer.example.com
ISSUER_SERVICE_API_KEY=your-api-key

# Upstash Redis (optional - for production rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token